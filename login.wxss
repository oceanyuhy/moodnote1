page {
  background-color: #fef5f8;
}
.icon-wrapper {
  display: inline-block;
}
.login-page {
  width: 100%;
  height: 100vh;
  box-sizing: border-box;
}
.form-box {
  padding: 40rpx 30rpx;
}
.input-item {
  width: 100%;
  height: 88rpx;
  border: 1rpx solid #eeeeee;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  background: #fff;
  margin-bottom: 10rpx;
  box-sizing: border-box;
}

/* 忘记密码 靠左对齐 */
.forget-row {
  display: flex;
  justify-content: flex-start;
  margin-top: 10rpx;
}
.forget-txt {
  font-size: 26rpx;
  color: #999;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(90deg, #ff87a2, #ff5a8c);
  color: #fff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-top: 10rpx;
}

/* 注册按钮 */
.register-row {
  margin-top: 20rpx;
}
.register-btn {
  width: 100%;
  height: 88rpx;
  background: #fff;
  color: #ff5a8c;
  border: 1rpx solid #ff5a8c;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}
/* 圆形LOGO */
.top-banner-box {
  display: flex;
  justify-content: center;
  margin-bottom: 60rpx;
}
.top-banner {
  margin-top: 50px;
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background: #f5f5f5;
}

/* 分割线 */
.line-box {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 50rpx 0;
  gap: 20rpx;
}
.line {
  width: 100rpx;
  height: 1rpx;
  background: #ddd;
}
.line-txt {
  font-size: 26rpx;
  color: #999;
}
/* 微信授权登陆样式 */
.wx-login-btn {
  background: #07c160;
  color: #fff;
  border-radius: 12rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  border: none;
  margin-top: 20rpx;
}
.wx-login-btn::after {
  border: none;
}

