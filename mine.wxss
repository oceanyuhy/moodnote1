.mine-page {
  background: #fef5f8;
  min-height: 100vh;
}

.user-card {
  background: linear-gradient(90deg, #ff95b6, #ff5a8c);
  padding: 60rpx 30rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  color: #fff;
  margin-bottom: 30rpx;
}
.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
}
.nickname {
  font-size: 36rpx;
  font-weight: bold;
}

.menu-item {
  background: #fff;
  padding: 30rpx;
  font-size: 30rpx;
  color: #333;
}

.action-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  visibility: hidden;
}
.action-sheet.show {
  visibility: visible;
}
.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
}
.sheet-body {
  background: #fff;
  border-radius: 20rpx 20rpx 0 0;
  padding: 20rpx;
  position: relative;
  z-index: 1;
}
.item {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 32rpx;
  color: #333;
  border-bottom: 1rpx solid #eee;
}
.item.delete {
  color: #ff3333;
}
.item.cancel {
  margin-top: 10rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  border: none;
}