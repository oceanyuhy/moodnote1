page {
  background: #fff;
}
.publish {
  padding: 20rpx;
  padding-top: 120rpx; /* 整体向下移动100rpx，解决被遮挡 */
}

/* 顶部 */
.pub-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}
.cancel {
  font-size: 32rpx;
  color: #333;
}
.publish-btn {
  background: #ff5a8c;
  color: #fff;
  padding: 12rpx 30rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
}

/* 输入框 */
.input-box {
  margin: 20rpx 0;
}
.input {
  width: 100%;
  min-height: 200rpx;
  font-size: 30rpx;
  line-height: 1.6;
}

/* 图片区域 */
.img-box {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 20rpx;
}
.img-item {
  width: 210rpx;
  height: 210rpx;
  position: relative;
}
.img-item image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}
.del {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  width: 40rpx;
  height: 40rpx;
  background: #ff3333;
  color: #fff;
  border-radius: 50%;
  text-align: center;
  line-height: 40rpx;
  font-size: 24rpx;
}
.add-img {
  width: 210rpx;
  height: 210rpx;
  background: #f7f7f7;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  color: #ccc;
}

/* 线 + 功能项 */
.line {
  height: 1rpx;
  background: #f0f0f0;
  margin: 30rpx 0;
}
.item {
  font-size: 30rpx;
  color: #333;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}