page {
  background-color: #fef5f8;
}
.register-page {
  padding: 40rpx 30rpx;
}

/* 圆形LOGO */
.logo-box {
  display: flex;
  justify-content: center;
  margin-bottom: 60rpx;
}
.logo {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background: #f5f5f5;
}

/* 表单 */
.form-box {
  width: 100%;
}
.input-item {
  width: 100%;
  height: 88rpx;
  border: 1rpx solid #eee;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  background: #fff;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

/* 验证码行 */
.code-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}
.code-input {
  width: 65%;
  height: 88rpx;
  border: 1rpx solid #eee;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  background: #fff;
  box-sizing: border-box;
}
.code-btn {
  width: 30%;
  height: 88rpx;
  background: #ff5a8c;
  color: #fff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
}

/* 注册按钮 */
.register-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(90deg, #ff87a2, #ff5a8c);
  color: #fff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-bottom: 20rpx;
}

/* 返回登录 靠右 */
.back-login {
  text-align: right;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 50rpx;
}

/* 分割线 */
.line-box {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 50rpx 0;
  gap: 20rpx;
}
.line {
  width: 100rpx;
  height: 1rpx;
  background: #ddd;
}
.line-txt {
  font-size: 26rpx;
  color: #999;
}

/* 第三方 */
.social-box {
  display: flex;
  justify-content: center;
  gap: 60rpx;
}
.icon {
  width: 60rpx;
  height: 60rpx;
}